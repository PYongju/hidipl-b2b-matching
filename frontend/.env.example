# 백엔드 API 서버 주소 (로컬: http://localhost:8000, 배포: Azure App Service URL)
VITE_API_BASE_URL=http://localhost:8000

# mock 모드 제어
# "false" 로 설정하면 실제 API 호출 (VITE_API_BASE_URL 필수)
# 미설정 또는 다른 값이면 mock 데이터 사용
VITE_USE_MOCK_API=true
#로그인 엔드포인트
VITE_AZURE_CLIENT_ID =""
VITE_AZURE_TENANT_ID=""
VITE_REDIRECT_URI =http://localhost:5173